{
  "name": "@dabb/client",
  "version": "2.0.0",
  "main": "index.ts",
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs');fs.mkdirSync('public',{recursive:true});fs.copyFileSync('../../node_modules/canvaskit-wasm/bin/full/canvaskit.wasm','public/canvaskit.wasm')\"",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "build:local": "eas build --local --platform android --profile preview",
    "bundle:web": "expo export --platform web",
    "clean": "rm -rf .expo dist"
  },
  "dependencies": {
    "@dabb/card-assets": "workspace:*",
    "@dabb/game-canvas": "workspace:*",
    "@dabb/game-logic": "workspace:*",
    "@dabb/i18n": "workspace:*",
    "@dabb/shared-types": "workspace:*",
    "@dabb/ui-shared": "workspace:*",
    "@expo-google-fonts/caveat": "^0.4.2",
    "@expo-google-fonts/im-fell-english-sc": "^0.4.0",
    "@expo-google-fonts/lato": "^0.4.1",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/react-native-skia": "^2.5.3",
    "buffer": "^6.0.3",
    "expo": "55.0.6",
    "expo-audio": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-haptics": "~55.0.9",
    "expo-linear-gradient": "^55.0.8",
    "expo-router": "~5.1.3",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "^55.0.10",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.4",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "~0.19.13",
    "react-native-worklets": "^0.7.4",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@expo/metro-config": "~55.0.9",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "~19.2.14",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.0"
  },
  "private": true
}
