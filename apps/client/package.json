{
  "name": "@dabb/client",
  "version": "2.2.1",
  "main": "index.ts",
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs');fs.mkdirSync('public',{recursive:true});fs.copyFileSync('../../node_modules/canvaskit-wasm/bin/full/canvaskit.wasm','public/canvaskit.wasm')\" && node -e \"if(process.platform==='linux'){require('child_process').execSync('npx install-skia',{stdio:'inherit'})}\"",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "build:local": "eas build --local --platform android --profile preview",
    "bundle:web": "expo export --platform web",
    "clean": "rm -rf .expo dist"
  },
  "dependencies": {
    "@dabb/card-assets": "workspace:*",
    "@dabb/game-ai": "workspace:*",
    "@dabb/game-canvas": "workspace:*",
    "@dabb/game-logic": "workspace:*",
    "@dabb/i18n": "workspace:*",
    "@dabb/shared-types": "workspace:*",
    "@dabb/ui-shared": "workspace:*",
    "@expo-google-fonts/caveat": "^0.4.2",
    "@expo-google-fonts/im-fell-english-sc": "^0.4.0",
    "@expo-google-fonts/lato": "^0.4.1",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "3.1.1",
    "@shopify/react-native-skia": "^2.6.8",
    "expo": "57.0.2",
    "expo-audio": "~57.0.0",
    "expo-clipboard": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "^57.0.5",
    "expo-haptics": "~57.0.0",
    "expo-linear-gradient": "^57.0.0",
    "expo-linking": "~57.0.1",
    "expo-navigation-bar": "~57.0.1",
    "expo-router": "~57.0.3",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "^57.0.2",
    "expo-status-bar": "~57.0.0",
    "firebase": "^12.16.0",
    "react": "19.2.7",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "^3.0.1",
    "react-native-get-random-values": "^2.0.0",
    "react-native-reanimated": "^4.4.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-svg": "^15.15.5",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "^0.10.1"
  },
  "devDependencies": {
    "@expo/metro-config": "~57.0.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "~19.2.17",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  },
  "private": true
}
