# Multi-stage build for @dabb/client web app
# Stage 1: Build
FROM cgr.dev/chainguard/node:latest-dev AS builder

USER root

# Install pnpm (corepack was removed from Node.js 25+; install pnpm directly)
RUN npm install -g pnpm@latest

WORKDIR /app

# Copy workspace configuration
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY scripts ./scripts

# Copy all package.json files for dependency resolution
COPY packages/shared-types/package.json ./packages/shared-types/
COPY packages/game-logic/package.json ./packages/game-logic/
COPY packages/game-canvas/package.json ./packages/game-canvas/
COPY packages/ui-shared/package.json ./packages/ui-shared/
COPY packages/i18n/package.json ./packages/i18n/
COPY packages/card-assets/package.json ./packages/card-assets/
COPY apps/client/package.json ./apps/client/

# Install dependencies (--ignore-scripts skips root postinstall which requires the full workspace)
RUN pnpm install --frozen-lockfile --ignore-scripts

# Run client postinstall manually: copy canvaskit.wasm to public/
RUN cd apps/client && node -e "const fs=require('fs');fs.mkdirSync('public',{recursive:true});fs.copyFileSync('../../node_modules/canvaskit-wasm/bin/full/canvaskit.wasm','public/canvaskit.wasm')"

# Copy source files
COPY packages/shared-types ./packages/shared-types
COPY packages/game-logic ./packages/game-logic
COPY packages/game-canvas ./packages/game-canvas
COPY packages/ui-shared ./packages/ui-shared
COPY packages/i18n ./packages/i18n
COPY packages/card-assets ./packages/card-assets
COPY apps/client ./apps/client
COPY tsconfig.base.json ./

# Build packages that expose pre-compiled dist/ (sequentially to respect dependencies)
RUN cd packages/shared-types && pnpm run build && \
    cd ../game-logic && pnpm run build && \
    cd ../i18n && pnpm run build && \
    cd ../ui-shared && pnpm run build

# Inject SERVER_URL into app.json extra so Expo bakes it into the bundle
ARG SERVER_URL
RUN node -e "const fs=require('fs'); const a=JSON.parse(fs.readFileSync('apps/client/app.json','utf8')); a.expo.extra.serverUrl=process.env.SERVER_URL; fs.writeFileSync('apps/client/app.json', JSON.stringify(a, null, 2));"

# Bundle the web app
RUN pnpm --filter @dabb/client bundle:web

# Stage 2: Serve with nginx
FROM cgr.dev/chainguard/nginx:latest

COPY --from=builder /app/apps/client/dist /usr/share/nginx/html
COPY apps/client/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 8080
