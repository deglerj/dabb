{
  "name": "dabb",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "description": "Binokel card game - multiplayer web and mobile app",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rm -rf node_modules",
    "typecheck": "turbo run typecheck",
    "docker:start": "./dev.sh start",
    "docker:stop": "./dev.sh stop",
    "docker:logs": "./dev.sh logs",
    "docker:status": "./dev.sh status",
    "docker:health": "./dev.sh health",
    "docker:reset": "./dev.sh reset",
    "simulate": "pnpm --filter @dabb/server simulate",
    "generate-licenses": "node scripts/generate-licenses.mjs",
    "postinstall": "node scripts/generate-licenses.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "react": "19.2.4",
      "socket.io-parser": "^4.2.6",
      "undici": "^7.24.5",
      "flatted": "^3.4.2",
      "minimatch@3>brace-expansion": "^1.1.13",
      "picomatch": "^4.0.4",
      "qs": "^6.14.2",
      "yaml": "^2.8.3"
    }
  }
}
