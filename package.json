{
  "name": "dabb",
  "version": "2.2.0",
  "private": true,
  "type": "module",
  "description": "Binokel card game - multiplayer web and mobile app",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "clean": "turbo run clean && rm -rf node_modules",
    "typecheck": "turbo run typecheck",
    "simulate": "pnpm --filter @dabb/simulate simulate",
    "generate-licenses": "node scripts/generate-licenses.mjs",
    "postinstall": "node scripts/generate-licenses.mjs && bash scripts/fix-hermes.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.71.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{json,md,yml,yaml}": [
      "oxfmt"
    ]
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@10.33.0"
}
