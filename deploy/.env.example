# Dabb Production Environment Configuration
# Copy this file to .env and fill in the values

# ===========================================
# REQUIRED VARIABLES
# ===========================================

# PostgreSQL password (use a strong, random password)
POSTGRES_PASSWORD=change_me_to_a_secure_password

# Public URL where the web app is accessible (for CORS)
# Example: https://dabb.degler.info
CLIENT_URL=https://dabb.degler.info

# Public URL where the server is accessible (for Socket.IO connection)
# Same as CLIENT_URL when using the nginx reverse proxy
# Example: https://dabb.degler.info
VITE_SERVER_URL=https://dabb.degler.info

# ===========================================
# OPTIONAL VARIABLES
# ===========================================

# Docker registry for pulling images (defaults to ghcr.io)
# DOCKER_REGISTRY=ghcr.io

# Image tag to deploy (defaults to latest)
# TAG=latest

# Override DATABASE_URL if using external PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/dabb

# ===========================================
# ANALYTICS — UMAMI (optional)
# ===========================================

# Secret for Umami JWT signing (generate with: openssl rand -hex 32)
# Required when Umami service is enabled
# UMAMI_APP_SECRET=change_me_to_a_secure_random_value

# Umami website ID — get from Umami dashboard after first login
# Server-side event tracking:
# UMAMI_WEBSITE_ID=
# Web app tracking (must be set at build time):
# VITE_UMAMI_URL=https://dabb.degler.info/umami
# VITE_UMAMI_WEBSITE_ID=
