{
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 100,
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules",
    "dist",
    "build",
    ".expo",
    "coverage",
    "*.lock",
    "pnpm-lock.yaml"
  ]
}
